{
	"name": "meadow-connection-manager",
	"version": "1.1.3",
	"description": "Server-side meadow connection manager. Parses connection configurations and instantiates database providers with graceful fallbacks for missing drivers.",
	"main": "source/Meadow-ConnectionManager.js",
	"scripts": {
		"start": "node source/Meadow-ConnectionManager.js",
		"test": "npx mocha -u tdd --exit --timeout 10000 test/*_tests.js"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "5000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		]
	},
	"keywords": [
		"meadow",
		"connection",
		"database",
		"provider",
		"manager"
	],
	"author": "Steven Velozo <steven@velozo.com>",
	"license": "MIT",
	"devDependencies": {
		"chai": "^4.3.10",
		"mocha": "^10.2.0",
		"pict-docuserve": "^1.4.12",
		"quackage": "^1.3.0"
	},
	"dependencies": {
		"fable-serviceproviderbase": "^3.0.19"
	},
	"peerDependencies": {
		"meadow-connection-mongodb": ">=1.0.0",
		"meadow-connection-mssql": ">=1.0.0",
		"meadow-connection-mysql": ">=1.0.0",
		"meadow-connection-oracle": ">=1.0.0",
		"meadow-connection-postgresql": ">=1.0.0",
		"meadow-connection-rocksdb": ">=1.0.0",
		"meadow-connection-solr": ">=1.0.0",
		"meadow-connection-sqlite": ">=1.0.0"
	},
	"peerDependenciesMeta": {
		"meadow-connection-mysql": {
			"optional": true
		},
		"meadow-connection-mssql": {
			"optional": true
		},
		"meadow-connection-oracle": {
			"optional": true
		},
		"meadow-connection-postgresql": {
			"optional": true
		},
		"meadow-connection-sqlite": {
			"optional": true
		},
		"meadow-connection-solr": {
			"optional": true
		},
		"meadow-connection-rocksdb": {
			"optional": true
		},
		"meadow-connection-mongodb": {
			"optional": true
		}
	}
}
