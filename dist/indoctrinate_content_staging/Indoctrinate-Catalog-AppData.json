            "Content": {
                "name": "meadow-connection-manager",
                "version": "1.0.0",
                "description": "Server-side meadow connection manager. Parses connection configurations and instantiates database providers with graceful fallbacks for missing drivers.",
                "main": "source/Meadow-ConnectionManager.js",
                "scripts": {
                    "start": "node source/Meadow-ConnectionManager.js",
                    "test": "npx quack test"
                },
                "mocha": {
                    "diff": true,
                    "extension": [
                        "js"
                    ],
                    "package": "./package.json",
                    "reporter": "spec",
                    "slow": "75",
                    "timeout": "5000",
                    "ui": "tdd",
                    "watch-files": [
                        "source/**/*.js",
                        "test/**/*.js"
                    ]
                },
                "keywords": [
                    "meadow",
                    "connection",
                    "database",
                    "provider",
                    "manager"
                ],
                "author": "Steven Velozo <steven@velozo.com>",
                "license": "MIT",
                "dependencies": {
                    "fable-serviceproviderbase": "^3.0.19"
                },
                "peerDependencies": {
                    "meadow-connection-mysql": ">=1.0.0",
                    "meadow-connection-mssql": ">=1.0.0",
                    "meadow-connection-postgresql": ">=1.0.0",
                    "meadow-connection-sqlite": ">=1.0.0",
                    "meadow-connection-solr": ">=1.0.0",
